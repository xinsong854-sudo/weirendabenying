# =============================================================================
# LLM 配置（必需 - 选择一种）
# =============================================================================

# 选项 1: LiteLLM (talesofai.cn) - 如果有账号
# LLM_PROVIDER=litellm
# LLM_URL=https://litellm.talesofai.cn/v1/chat/completions
# LLM_API_KEY=sk-你的key
# LLM_MODEL=qwen3.5-plus-no-think
# LLM_THINKING_MODEL=qwen3.5-plus

# 选项 2: OpenRouter (推荐 - 有免费模型)
# 注册: https://openrouter.ai
LLM_PROVIDER=openrouter
LLM_API_KEY=sk-or-v1-你的openrouterkey
LLM_MODEL=qwen/qwen-2.5-7b-instruct:free
LLM_THINKING_MODEL=deepseek/deepseek-r1:free

# 选项 3: OpenAI
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-你的openaikey
# LLM_MODEL=gpt-4o-mini
# LLM_THINKING_MODEL=gpt-4o

# =============================================================================
# 安全配置（可选）
# =============================================================================

# 访问密钥（设置后前端需要传递正确的 key 才能调用）
# DTAGS_API_KEY=your-custom-access-key

# 频率限制
RATE_LIMIT=20
RATE_LIMIT_HOUR=100

# 允许的跨域来源（逗号分隔）
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# 请求日志
LOG_REQUESTS=true
